    def _on_perf_mode_changed(self, btn_id: int, checked: bool):
        if not checked:
            return
        mode = ["low", "medium", "high"][btn_id]
        self._settings["perf_mode"] = mode
        _save_settings(self._settings)
        cfg = PERF_PRESETS[mode]
        self._log(f"⚡ Режим: {mode} ({cfg['test_threads']}потоков, {cfg['max_repos']}репо)")

    def _on_check_github_token(self):
        tokens = [t.strip() for t in self.github_tokens_edit.toPlainText().strip().splitlines() if t.strip()]
        if not tokens:
            self._log("⛔ Нет токенов для проверки")
            if hasattr(self, 'settings_status'):
                self.settings_status.setText("⛔ Введите токены")
            return
        self._log(f"🔍 Проверка {len(tokens)} токенов GitHub...")
        if hasattr(self, 'settings_status'):
            self.settings_status.setText("⏳ Проверка токенов...")
        self.btn_check_token.setEnabled(False)
        ok_count = 0
        for i, token in enumerate(tokens):
            if not token.startswith(("ghp_", "gho_", "ghu_", "ghs_", "ghr_", "github_pat_")):
                self._log(f"  ⏭ Токен #{i+1}: неверный формат")
                continue
            try:
                req = urllib.request.Request("https://api.github.com/user", headers={
                    "Authorization": f"Bearer {token}", "User-Agent": "proxy-fetcher/2.0",
                })
                for use_proxy in (False, True):
                    opener, _ = _get_proxy_opener(timeout=8) if use_proxy else (urllib.request.build_opener(), {})
                    try:
                        with opener.open(req, timeout=8) as resp:
                            data = json.loads(resp.read())
                            login = data.get("login", "?")
                            self._log(f"  ✅ Токен #{i+1}: {login}")
                            ok_count += 1
                            break
                    except urllib.error.HTTPError as e:
                        if e.code == 401:
                            self._log(f"  ⛔ Токен #{i+1}: недействителен (401)")
                        elif e.code == 403:
                            self._log(f"  ⚠️ Токен #{i+1}: лимит запросов (403)")
                        elif e.code == 304:
                            self._log(f"  ✅ Токен #{i+1}: OK (304)")
                            ok_count += 1
                        else:
                            self._log(f"  ⚠️ Токен #{i+1}: ошибка {e.code}")
                        break
                    except Exception:
                        continue
                else:
                    self._log(f"  ⛔ Токен #{i+1}: нет соединения")
            except Exception as e:
                self._log(f"  ⛔ Токен #{i+1}: {e}")
        self._log(f"✅ Работает: {ok_count}/{len(tokens)}")
        if hasattr(self, 'settings_status'):
            self.settings_status.setText(f"✅ {ok_count}/{len(tokens)} токенов работают" if ok_count else "⛔ Ни один токен не работает")
        self.btn_check_token.setEnabled(True)

