    def _on_source_double_click(self, item, column):
        url = item.data(1, Qt.ItemDataRole.UserRole)
        if not url: return

        class _DialogSlot(QObject):
            result_signal = Signal(str)
            error_signal = Signal(str)

            def __init__(self, widget):
                super().__init__()
                self._w = widget
                self.result_signal.connect(self._on_result, Qt.ConnectionType.QueuedConnection)
                self.error_signal.connect(self._on_error, Qt.ConnectionType.QueuedConnection)

            @Slot(str)
            def _on_result(self, data):
                self._w.setPlainText(data)

            @Slot(str)
            def _on_error(self, err):
                self._w.setPlainText(f"✗ Ошибка: {err}")

        dlg = QDialog(self)
        dlg.setWindowTitle(f"Содержимое: {item.text(1)}")
        dlg.setMinimumSize(500, 400)
        layout = QVBoxLayout(dlg)
        text = QTextEdit()
        text.setReadOnly(True)
        text.setFont(QFont("monospace", 9))
        text.setPlainText("⏳ Загрузка...")
        layout.addWidget(text)
        btn_box = QDialogButtonBox(QDialogButtonBox.StandardButton.Close)
        btn_box.rejected.connect(dlg.reject)
        layout.addWidget(btn_box)

        slot = _DialogSlot(text)
        thread = QThread()
        worker = _SourceFetcher(url)
        worker.moveToThread(thread)
        worker.result.connect(slot.result_signal, Qt.ConnectionType.QueuedConnection)
        worker.error.connect(slot.error_signal, Qt.ConnectionType.QueuedConnection)
        thread.started.connect(worker.run, Qt.ConnectionType.DirectConnection)
        thread.finished.connect(thread.deleteLater)
        thread.start()
        dlg.exec_()
        thread.quit()
        thread.wait(2000)

    def _kill_thread(self, thread, name="thread"):
        if not thread: return
        thread.quit()
        if not thread.wait(500):
            self._log(f"  ⚠ Принудительное завершение {name}...")
            thread.terminate()
            thread.wait(500)

