    def _auto_save_subscription(self):
        proxies = self.proxy_model.proxies
        working = [p for p in proxies if p.deep_ok is True or p.tcp_ok is True]
        if not working:
            working = proxies
        try:
            with open(os.path.join(OUT_DIR, "latest.txt"), "w") as f:
                f.write(format_v2rayn(working))
            # Hiddify-совместимый plain text
            plain_lines = [
                "#profile-title: skitchen VPN",
                "#profile-update-interval: 1",
                "",
            ]
            for p in working:
                plain_lines.append(p.uri)
            with open(os.path.join(OUT_DIR, "hiddify_sub.txt"), "w") as f:
                f.write("\n".join(plain_lines) + "\n")
            if self._http_server_proc is not None:
                self._stop_http_server()
                self._start_http_server()
        except Exception:
            pass

