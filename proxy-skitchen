    # ─── STATS ───

    def _on_show_stats(self):
        proxies = self.proxy_model.proxies
        if not proxies: return

        proto_counter = Counter(p.protocol for p in proxies)
        country_counter = Counter(p.country for p in proxies if p.country)
        tcp_ok = sum(1 for p in proxies if p.tcp_ok is True)
        deep_ok = sum(1 for p in proxies if p.deep_ok is True)
        sni_ok = sum(1 for p in proxies if p.sni_good)

        latencies = [p.latency_ms for p in proxies if p.latency_ms is not None]
        avg_lat = sum(latencies) / len(latencies) if latencies else 0

        # Latency histogram
        hist_buckets = {"<100ms": 0, "100-200ms": 0, "200-500ms": 0, "500ms+": 0}
        for l in latencies:
            if l < 100: hist_buckets["<100ms"] += 1
            elif l < 200: hist_buckets["100-200ms"] += 1
            elif l < 500: hist_buckets["200-500ms"] += 1
            else: hist_buckets["500ms+"] += 1

        d = QDialog(self)
        d.setWindowTitle("📊 Статистика")
        d.setMinimumSize(450, 400)
        l = QVBoxLayout(d)

        lines = [
            f"┌─{'─'*40}─┐",
            f"│  ОБЩАЯ СТАТИСТИКА",
            f"├─{'─'*40}─┤",
            f"│  Всего прокси:      {len(proxies)}",
            f"│  TCP OK:            {tcp_ok}",
            f"│  Deep OK:           {deep_ok}",
            f"│  SNI-фильтр:        {sni_ok}",
            f"│  Средняя задержка:  {avg_lat:.0f}ms",
            f"├─{'─'*40}─┤",
            f"│  ПО ПРОТОКОЛАМ",
        ]
        for proto, count in proto_counter.most_common():
            lines.append(f"│    {proto:10s}: {count}")
        lines.append(f"├─{'─'*40}─┤")
        lines.append(f"│  ПО СТРАНАМ (топ-10)")
        for country, count in country_counter.most_common(10):
            lines.append(f"│    {country:15s}: {count}")
        lines.append(f"├─{'─'*40}─┤")
        lines.append(f"│  ГИСТОГРАММА ЗАДЕРЖЕК")
        for bucket, count in hist_buckets.items():
            bar = "█" * min(count, 30) + (f" ({count})" if count > 0 else "")
            lines.append(f"│    {bucket:15s}: {bar}")
        lines.append(f"└─{'─'*40}─┘")

        t = QTextEdit()
        t.setReadOnly(True)
        t.setFont(QFont("monospace", 10))
        t.setText("\n".join(lines))
        l.addWidget(t)

        b = QDialogButtonBox(QDialogButtonBox.StandardButton.Close)
        b.rejected.connect(d.reject)
        l.addWidget(b)
        d.exec_()

