    def _apply_settings(self):
        s = self._settings
        self.github_tokens_edit.setPlainText("\n".join(_auth_data.get("github_tokens", [])))
        self.cb_proxy_enable.setChecked(s.get("proxy_enabled", True))
        self.proxy_type_combo.setCurrentText(s.get("proxy_type", "HTTP").upper())
        self.proxy_host_edit.setText(s.get("proxy_host", "127.0.0.1"))
        self.proxy_port_spin.setValue(s.get("proxy_port", 12334))
        self._sync_proxy_ui()
        # Восстанавливаем прокси из кэша (макс 200)
        cached = s.get("proxy_cache", [])
        if cached:
            entries = []
            for item in cached[:200]:
                entry = ProxyEntry(item.get("uri", ""), item.get("source", ""))
                entry.tcp_ok = item.get("tcp_ok")
                entry.deep_ok = item.get("deep_ok")
                entry.latency_ms = item.get("latency_ms")
                entries.append(entry)
            self.proxy_model.add_proxies(entries)
            self._log(f"📂 Восстановлено {len(entries)} прокси из кэша.")
        mode = s.get("perf_mode", "medium")
        idx = {"low": 0, "medium": 1, "high": 2}.get(mode, 1)
        if idx < len(self.perf_btns):
            self.perf_btns[{"low": "low", "medium": "medium", "high": "high"}[mode]].setChecked(True)
        self._set_busy(False)
        self._update_stats()

    def _sync_proxy_ui(self):
        pass  # настройки всегда доступны для редактирования

