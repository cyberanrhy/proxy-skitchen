_proxy_cache: dict | None = None

def _get_proxy_opener(timeout: int = 8) -> tuple[urllib.request.OpenerDirector, dict]:
    """Return (opener, proxy_dict) based on current settings."""
    global _proxy_cache
    if _proxy_cache is None:
        _proxy_cache = _load_settings()
    s = _proxy_cache
    if not s.get("proxy_enabled"):
        return urllib.request.build_opener(), {}
    ptype = s.get("proxy_type", "http")
    host = s.get("proxy_host", "127.0.0.1")
    port = s.get("proxy_port", 12334)
    if ptype == "socks5":
        handler = SocksiPyHandler(socks.SOCKS5, host, port)
        return urllib.request.build_opener(handler), {}
    url = f"http://{host}:{port}"
    pd = {"http": url, "https": url}
    handler = urllib.request.ProxyHandler(pd)
    return urllib.request.build_opener(handler), pd

def _invalidate_proxy_cache():
    global _proxy_cache
    _proxy_cache = None



