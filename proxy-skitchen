    def _on_table_context_menu(self, pos):
        """Контекстное меню правой кнопки мыши на таблице прокси."""
        indexes = self.table.selectionModel().selectedRows()
        if not indexes:
            return

        menu = QMenu(self)
        copy_one_action = menu.addAction("📋 Копировать URI в буфер")
        menu.addSeparator()
        copy_all_action = menu.addAction("📋 Копировать ВСЕ URI (выделенные)")

        action = menu.exec(self.table.viewport().mapToGlobal(pos))
        if action == copy_one_action:
            # Копируем URI первой выбранной строки
