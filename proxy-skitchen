class ProxyEntry:
    def __init__(self, uri: str, source: str = ""):
        self.uri = uri
        self.source = source
        self.protocol = get_protocol(uri)
        self.server, self.port = get_server_port(uri)
        self.sni = extract_sni(uri) or ""
        self.remark = get_remark(uri)
        self.country = guess_country(uri)
        self.sni_good = sni_is_good(uri)
        self.tcp_ok: Optional[bool] = None
        self.deep_ok: Optional[bool] = None
        self.latency_ms: Optional[float] = None
        self.error_msg: str = ""

    @property
    def server_display(self) -> str:
        if self.server and self.port:
            return f"{self.server}:{self.port}"
        return self.server or "?"

    def __repr__(self):
        return f"[{self.protocol}] {self.server_display}"


COLUMNS = ["✓", "Протокол", "Сервер:Порт", "SNI", "Страна", "Источник", "TCP", "Deep", "Латентность", "Remark"]

class ProxyTableModel(QAbstractTableModel):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.proxies: list[ProxyEntry] = []

    def rowCount(self, parent=QModelIndex()):
        return len(self.proxies)

    def columnCount(self, parent=QModelIndex()):
        return len(COLUMNS)

    def data(self, index: QModelIndex, role=Qt.ItemDataRole.DisplayRole):
        if not index.isValid() or index.row() >= len(self.proxies):
            return None
        p = self.proxies[index.row()]
        col = index.column()

        if role in (Qt.ItemDataRole.DisplayRole, Qt.ItemDataRole.ToolTipRole):
            vals = {
                0: "✅" if p.deep_ok is True else ("❌" if p.deep_ok is False else ("✓" if p.tcp_ok is True else ("✗" if p.tcp_ok is False else "?"))),
                1: p.protocol,
                2: p.server_display,
                3: p.sni if p.sni else "—",
                4: p.country if p.country else "—",
                5: p.source,
                6: "✅" if p.tcp_ok is True else ("❌" if p.tcp_ok is False else "—"),
                7: "✅" if p.deep_ok is True else ("❌" if p.deep_ok is False else "—"),
                8: f"{p.latency_ms:.0f}ms" if p.latency_ms else "—",
                9: p.remark[:60] if p.remark else "—",
            }
            return vals.get(col, "")
        return None

    def headerData(self, section, orientation, role=Qt.ItemDataRole.DisplayRole):
        if orientation == Qt.Orientation.Horizontal and role == Qt.ItemDataRole.DisplayRole:
            return COLUMNS[section]
        return None

    def add_proxies(self, entries: list[ProxyEntry]):
        if not entries: return
        self.beginInsertRows(QModelIndex(), len(self.proxies), len(self.proxies) + len(entries) - 1)
        self.proxies.extend(entries)
        self.endInsertRows()

    def clear(self):
        self.beginResetModel()
        self.proxies.clear()
        self.endResetModel()

    def update_entry(self, row: int, **kwargs):
        if 0 <= row < len(self.proxies):
            for k, v in kwargs.items():
                setattr(self.proxies[row], k, v)
            changed_cols = {0, 6, 7, 8}  # статус, TCP, Deep, latency
            min_col = min(changed_cols)
            max_col = max(changed_cols)
            self.dataChanged.emit(self.index(row, min_col), self.index(row, max_col))


class ProxyFilterModel(QSortFilterProxyModel):
    def __init__(self, parent=None):
        super().__init__(parent)
        self._filter_text = ""
        self._filter_proto = ""
        self._filter_country = ""
        self._filter_sni_good_only = False
        self._filter_deep_good_only = False

    def set_filter_text(self, text: str):
        self._filter_text = text.lower()
        self.invalidateFilter()

    def set_filter_proto(self, proto: str):
        self._filter_proto = proto
        self.invalidateFilter()

    def set_filter_country(self, country: str):
        self._filter_country = country
        self.invalidateFilter()

    def set_filter_sni_good(self, v: bool):
        self._filter_sni_good_only = v
        self.invalidateFilter()

    def set_filter_deep_good(self, v: bool):
        self._filter_deep_good_only = v
        self.invalidateFilter()

    def filterAcceptsRow(self, source_row: int, source_parent: QModelIndex) -> bool:
        model: ProxyTableModel = self.sourceModel()
        if source_row >= len(model.proxies): return False
        p = model.proxies[source_row]

        if self._filter_text:
            t = self._filter_text
            if t not in p.server_display.lower() and t not in p.sni.lower() and \
               t not in p.remark.lower() and t not in p.protocol.lower() and \
               t not in p.country.lower() and t not in p.source.lower():
                return False

        if self._filter_proto and p.protocol != self._filter_proto:
            return False

        if self._filter_country:
            if self._filter_country == "_empty" and p.country: return False
            elif self._filter_country != "_empty" and p.country != self._filter_country: return False

        if self._filter_sni_good_only and not p.sni_good: return False
        if self._filter_deep_good_only and p.deep_ok is not True: return False

        return True


