class ProxyTester:
    """Тестирует прокси через sing-box."""

    TEST_URL = "http://cp.cloudflare.com/generate_204"
    TEST_DOMAIN = "cloudflare.com"
    TIMEOUT = 12  # seconds

    _sb_semaphore = threading.Semaphore(3)

    def __init__(self):
        self.resolved_ips: dict[str, str] = {}
        self.stats = Counter()

    def resolve_host(self, host: str) -> Optional[str]:
        if host in self.resolved_ips:
            return self.resolved_ips[host]
        try:
            addrs = socket.getaddrinfo(host, 80, socket.AF_INET, socket.SOCK_STREAM)
            if addrs:
                ip = addrs[0][4][0]
                self.resolved_ips[host] = ip
                return ip
        except Exception:
            pass
        return None

    def test_tcp(self, host: str, port: int) -> bool:
        try:
            addrs = socket.getaddrinfo(host, port, socket.AF_INET, socket.SOCK_STREAM)
            if not addrs: return False
            s = socket.socket(addrs[0][0], addrs[0][1], addrs[0][2])
            s.settimeout(12)
            s.connect(addrs[0][4])
            s.close()
            return True
        except Exception:
            return False

    def test_tls_handshake(self, host: str, sni: str = "") -> bool:
        """Проверяет TLS-рукопожатие (для vless/trojan/vmess)."""
        try:
            ctx = ssl.create_default_context()
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
            ctx.set_alpn_protocols(["h2", "http/1.1"])
            addrs = socket.getaddrinfo(host, 443, socket.AF_INET, socket.SOCK_STREAM)
            if not addrs: return False
            s = socket.socket(addrs[0][0], addrs[0][1], addrs[0][2])
            s.settimeout(12)
            s.connect(addrs[0][4])
            tls_sock = ctx.wrap_socket(s, server_hostname=sni or host)
            tls_sock.do_handshake()
            tls_sock.close()
            return True
        except Exception:
            return False

    def test_via_singbox(self, proxy_uri: str, port: int) -> tuple[bool, float, str, Optional[subprocess.Popen]]:
        """Тестирует прокси через sing-box: запускает, подключается, измеряет latency."""
        tmp_dir = tempfile.mkdtemp(prefix="sb_test_", dir=TMP_DIR)
        config_path = os.path.join(tmp_dir, "config.json")

        config = self._make_singbox_config(proxy_uri, port)
        if config is None:
            return False, 0, "unsupported protocol", None

        with open(config_path, "w") as f:
            json.dump(config, f, indent=2)

        try:
            with self._sb_semaphore:
                time.sleep(random.uniform(0.1, 0.4))
                proc = subprocess.Popen(
                    [SING_BOX, "run", "-c", config_path],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                    cwd=tmp_dir,
                )
                time.sleep(0.3)
                proxy_url = f"http://127.0.0.1:{port}"
                result, latency = self._test_http_proxy(proxy_url)
                proc.terminate()
                proc.wait(3)

            return result, latency if result else 0, "" if result else f"latency:{latency:.0f}ms", proc
        except Exception as e:
            return False, 0, str(e), None
        finally:
            # Cleanup
            try:
                subprocess.run(["pkill", "-f", config_path], capture_output=True, timeout=2)
            except Exception:
                pass
            try:
                for f in os.listdir(tmp_dir):
                    os.remove(os.path.join(tmp_dir, f))
                os.rmdir(tmp_dir)
            except Exception:
                pass

    def _make_singbox_config(self, proxy_uri: str, local_port: int) -> Optional[dict]:
        """Генерирует конфиг sing-box для тестирования одного прокси."""
        proto = get_protocol(proxy_uri)
        outbounds = [self._parse_outbound(proxy_uri)]
        if outbounds[0] is None:
            return None
        outbounds[0]["tag"] = "proxy"
        return {
            "log": {"level": "error", "output": "/dev/null"},
            "inbounds": [{
                "type": "http",
                "tag": "http-in",
                "listen": "127.0.0.1",
                "listen_port": local_port,
            }],
            "outbounds": outbounds + [{"type": "direct", "tag": "direct"}],
            "route": {
                "rules": [{"rule_set": [], "outbound": "proxy"}],
                "final": "proxy",
            },
        }

    def _parse_outbound(self, uri: str) -> Optional[dict]:
        """Парсит URI в outbound-конфиг sing-box."""
        try:
            proto = get_protocol(uri)
            line = uri.strip()
            l = line.lower()

            if proto == 'vless':
                return self._parse_vless(line)
            elif proto == 'trojan':
                return self._parse_trojan(line)
            elif proto == 'vmess':
                return self._parse_vmess(line)
            elif proto == 'ss':
                return self._parse_ss(line)
            elif proto in ('hy2', 'hysteria2'):
                return self._parse_hysteria2(line)
            elif proto == 'socks':
                return self._parse_socks(line)
            elif proto == 'http':
                return self._parse_http(line)
            else:
                return None
        except Exception:
            return None

    def _parse_query(self, uri: str) -> dict:
        qmark = uri.find('?')
        if qmark == -1: return {}
        return urllib.parse.parse_qs(uri[qmark + 1:])

    def _query_get(self, q: dict, key: str, default=""):
        vals = q.get(key, [])
        return vals[0] if vals else default

    def _parse_vless(self, uri: str) -> dict:
        clean = uri.replace('vless://', '')
        q = self._parse_query(clean)
        at_idx = clean.find('@')
        uuid = clean[:at_idx]
        rest = clean[at_idx + 1:]
        qm = rest.find('?')
        host_part = rest[:qm] if qm != -1 else rest
        colon = host_part.rfind(':')
        host = host_part[:colon]
        p = host_part[colon + 1:]
        try: port = int(p)
        except: port = 443
        flow = self._query_get(q, 'flow')
        security = self._query_get(q, 'security', '')
        sni = self._query_get(q, 'sni', host)
        alpn_str = self._query_get(q, 'alpn', '')
        fp = self._query_get(q, 'fp', 'chrome')

        packet_enc = self._query_get(q, 'packet_encoding', 'xudp')
        encrypt = self._query_get(q, 'encryption', 'none')

        out = {
            "type": "vless",
            "server": host,
            "server_port": port,
            "uuid": uuid,
            "flow": flow,
            "packet_encoding": packet_enc,
        }
        if security == 'reality':
            pbk = self._query_get(q, 'pbk')
            sid = self._query_get(q, 'sid', '')
            spx = self._query_get(q, 'spx', '/')
            out["tls"] = {
                "enabled": True,
                "server_name": sni or host,
                "utls": {"enabled": True, "fingerprint": fp},
                "reality": {"enabled": True, "public_key": pbk, "short_id": sid},
            }
        elif security in ('tls', 'xtls', ''):
            out["tls"] = {"enabled": True, "server_name": sni or host}

        ttype = self._query_get(q, 'type', 'tcp')
        if ttype == 'ws':
            path = self._query_get(q, 'path', '/')
            host_hdr = self._query_get(q, 'host', sni or host)
            out["transport"] = {"type": "ws", "path": path, "headers": {"Host": host_hdr}}
        elif ttype == 'grpc':
            service_name = self._query_get(q, 'serviceName', '')
            out["transport"] = {"type": "grpc", "service_name": service_name}
        elif ttype == 'xhttp':
            mode = self._query_get(q, 'mode', 'auto')
            out["transport"] = {"type": "xhttp", "mode": mode}
        return out

    def _parse_trojan(self, uri: str) -> dict:
        clean = uri.replace('trojan://', '')
        q = self._parse_query(clean)
        at_idx = clean.find('@')
        password = clean[:at_idx]
        rest = clean[at_idx + 1:]
        qm = rest.find('?')
        host_part = rest[:qm] if qm != -1 else rest
        colon = host_part.rfind(':')
        host = host_part[:colon]
        p = host_part[colon + 1:]
        try: port = int(p)
        except: port = 443
        sni = self._query_get(q, 'sni', host)
        alpn_str = self._query_get(q, 'alpn', '')
        fp = self._query_get(q, 'fp', 'chrome')
        out = {"type": "trojan", "server": host, "server_port": port, "password": password}
        out["tls"] = {"enabled": True, "server_name": sni or host}
        if fp:
            out["tls"]["utls"] = {"enabled": True, "fingerprint": fp}
        ttype = self._query_get(q, 'type', 'tcp')
        if ttype == 'ws':
            path = self._query_get(q, 'path', '/')
            host_hdr = self._query_get(q, 'host', sni or host)
            out["transport"] = {"type": "ws", "path": path, "headers": {"Host": host_hdr}}
        elif ttype == 'grpc':
            service_name = self._query_get(q, 'serviceName', '')
            out["transport"] = {"type": "grpc", "service_name": service_name}
        elif ttype == 'xhttp':
            out["transport"] = {"type": "xhttp", "mode": self._query_get(q, 'mode', 'auto')}
        return out

    def _parse_vmess(self, uri: str) -> Optional[dict]:
        b64 = uri.replace('vmess://', '')
        pad = 4 - len(b64) % 4
        if pad != 4: b64 += '=' * pad
        data = json.loads(base64.b64decode(b64))
        host = data.get('add', '')
        port = int(data.get('port', 443))
        uuid = data.get('id', '')
        aid = int(data.get('aid', 0))
        net = data.get('net', 'tcp')
        tls = data.get('tls', '')
        sni = data.get('sni', host)
        path = data.get('path', '/')
        host_hdr = data.get('host', host)
        fp = data.get('fp', 'chrome')
        type_hdr = data.get('type', 'none')
        out = {"type": "vmess", "server": host, "server_port": port, "uuid": uuid, "alter_id": aid}
        if tls:
            out["tls"] = {"enabled": True, "server_name": sni or host}
            if fp:
                out["tls"]["utls"] = {"enabled": True, "fingerprint": fp}
        if net == 'ws':
            out["transport"] = {"type": "ws", "path": path, "headers": {"Host": host_hdr}}
        elif net == 'grpc':
            out["transport"] = {"type": "grpc", "service_name": path.lstrip('/')}
        elif net == 'http':
            out["transport"] = {"type": "http"}
        return out

    def _parse_ss(self, uri: str) -> Optional[dict]:
        clean = uri.replace('ss://', '')
        q = self._parse_query(clean)
        # ss://method:pass@host:port  or  ss://base64(method:pass)@host:port
        at_idx = clean.find('@')
        if at_idx == -1:
            # format: ss://base64(method:pass@host:port)
            b64_part = clean.split('?')[0].split('#')[0]
            try:
                pad = 4 - len(b64_part) % 4
                if pad != 4: b64_part += '=' * pad
                decoded = base64.b64decode(b64_part).decode('utf-8', errors='ignore')
                at_idx2 = decoded.find('@')
                if at_idx2 == -1: return None
                mp = decoded[:at_idx2]
                hp = decoded[at_idx2 + 1:]
            except:
                return None
        else:
            mp_b64 = clean[:at_idx]
            try:
                pad = 4 - len(mp_b64) % 4
                if pad != 4: mp_b64 += '=' * pad
                mp = base64.b64decode(mp_b64).decode('utf-8', errors='ignore')
            except:
                mp = mp_b64
            hp = clean[at_idx + 1:]
        qm = hp.find('?')
        if qm != -1: hp = hp[:qm]
        colon = hp.rfind(':')
        host = hp[:colon]
        p = hp[colon + 1:]
        try: port = int(p)
        except: port = 443
        colon2 = mp.find(':')
        method = mp[:colon2]
        password = mp[colon2 + 1:]
        plugin_str = self._query_get(q, 'plugin', '')
        out = {"type": "shadowsocks", "server": host, "server_port": port, "method": method, "password": password}
        if plugin_str:
            out["plugin"] = plugin_str
        return out

    def _parse_hysteria2(self, uri: str) -> Optional[dict]:
        clean = uri.replace('hysteria2://', '').replace('hy2://', '')
        q = self._parse_query(clean)
        auth = self._query_get(q, 'auth', '')
        at_idx = clean.find('@')
        if at_idx != -1:
            auth = clean[:at_idx]
            rest = clean[at_idx + 1:]
        else:
            auth = self._query_get(q, 'auth', clean.split('?')[0].split('#')[0])
            rest = clean
        qm = rest.find('?')
        host_part = rest[:qm] if qm != -1 else rest
        colon = host_part.rfind(':')
        host = host_part[:colon] if colon != -1 else host_part
        p = host_part[colon + 1:] if colon != -1 else '443'
        try: port = int(p)
        except: port = 443
        sni = self._query_get(q, 'sni', host)
        insecure = self._query_get(q, 'insecure', '0') in ('1', 'true')
        out = {"type": "hysteria2", "server": host, "server_port": port, "password": auth, "tls": {"enabled": True, "server_name": sni or host, "insecure": insecure}}
        return out

    def _parse_socks(self, uri: str) -> Optional[dict]:
        l = uri.strip().lower()
        version = 5 if l.startswith('socks5://') else 4
        clean = uri.replace('socks5://', '').replace('socks4://', '')
        at_idx = clean.find('@')
        user = passwd = ''
        if at_idx != -1:
            user_pass = clean[:at_idx]
            colon = user_pass.find(':')
            if colon != -1:
                user = user_pass[:colon]
                passwd = user_pass[colon + 1:]
            rest = clean[at_idx + 1:]
        else:
            rest = clean
        qm = rest.find('?')
        if qm != -1: rest = rest[:qm]
        h = rest.find('#')
        if h != -1: rest = rest[:h]
        colon = rest.rfind(':')
        host = rest[:colon]
        p = rest[colon + 1:]
        try: port = int(p)
        except: port = 1080
        out = {"type": "socks", "server": host, "server_port": port, "version": f"Socks{version}"}
        if user: out["username"] = user
        if passwd: out["password"] = passwd
        return out

    def _parse_http(self, uri: str) -> Optional[dict]:
        clean = uri.replace('https://', '').replace('http://', '')
        qm = clean.find('?')
        if qm != -1: clean = clean[:qm]
        h = clean.find('#')
        if h != -1: clean = clean[:h]
        at_idx = clean.find('@')
        user = passwd = ''
        if at_idx != -1:
            up = clean[:at_idx]
            colon = up.find(':')
            if colon != -1:
                user = up[:colon]
                passwd = up[colon + 1:]
            clean = clean[at_idx + 1:]
        colon = clean.rfind(':')
        host = clean[:colon]
        p = clean[colon + 1:]
        try: port = int(p)
        except: port = 8080
        out = {"type": "http", "server": host, "server_port": port}
        if user: out["username"] = user
        if passwd: out["password"] = passwd
        return out

    def _test_http_proxy(self, proxy_url: str, timeout: float = 8) -> tuple[bool, float]:
        """Делает HTTP-запрос через SOCKS5-прокси, измеряет latency."""
        import urllib.request as req_lib
        try:
            start = time.time()
            handler = urllib.request.ProxyHandler({"http": proxy_url, "https": proxy_url})
            opener = req_lib.build_opener(handler)
            r = opener.open(self.TEST_URL, timeout=timeout)
            elapsed = (time.time() - start) * 1000
            return r.status == 204, elapsed
        except Exception:
            return False, (time.time() - start) * 1000 if 'start' in dir() else 9999


