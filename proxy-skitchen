    # ─── DEDUP ───

    def _on_dedup(self):
        proxies = self.proxy_model.proxies
        if not proxies: return
        before = len(proxies)
        # Группируем по server:port (без DNS — не блокируем UI)
        seen: dict[str, list[int]] = {}
        for i, p in enumerate(proxies):
            key = f"{p.server}:{p.port}" if p.server else f"none:{i}"
            seen.setdefault(key, []).append(i)

        to_remove = set()
        for key, indices in seen.items():
            if len(indices) <= 1: continue
            scored = []
            for idx in indices:
                p = proxies[idx]
                score = 0
                if p.deep_ok is True: score = 3
                elif p.tcp_ok is True: score = 2
                elif p.tcp_ok is False: score = -1
                scored.append((score, p.latency_ms or 9999, idx))
            scored.sort(key=lambda x: (-x[0], x[1]))
            for _, _, idx in scored[1:]:
                to_remove.add(idx)

        for idx in sorted(to_remove, reverse=True):
            del proxies[idx]

        self.proxy_model.beginResetModel()
        self.proxy_model.endResetModel()
        after = len(proxies)
        self._log(f"🧹 Смарт-дедуп: {before} → {after} (удалено {before-after})")
        self._update_stats()

