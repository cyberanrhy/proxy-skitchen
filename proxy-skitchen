    def _on_test_result(self, row: int, ok: bool, latency: float, error: str, ttype: int):
        if ttype == 0:  # TCP
            self.proxy_model.update_entry(row, tcp_ok=ok, latency_ms=latency if ok else None, error_msg=error)
        else:  # Deep
            self.proxy_model.update_entry(row, deep_ok=ok, latency_ms=latency if ok else None, error_msg=error)
        self._update_stats()
        sm = self.filter_model.sourceModel()
        if 0 <= row < sm.rowCount():
            filt_idx = self.filter_model.mapFromSource(sm.index(row, 0))
            if filt_idx.isValid():
                self.table.selectRow(filt_idx.row())
                self.table.scrollTo(filt_idx, QAbstractItemView.ScrollHint.EnsureVisible)

