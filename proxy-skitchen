            lines.append(f"    port: {p.port}")
            lines.append(f"    cipher: auto")
            lines.append(f"    password: auto")
    return "\n".join(lines)


def uri_to_singbox(uri: str) -> dict | None:
    """Конвертирует proxy URI в outbound для sing-box."""
    try:
        proto = uri.split("://")[0]
        if proto == "vmess":
            b64 = uri[8:]
            padding = 4 - len(b64) % 4
            if padding != 4: b64 += "=" * padding
            cfg = json.loads(base64.b64decode(b64).decode())
            out = {"type": "vmess", "tag": cfg.get("ps", "vmess"), "server": cfg.get("add", ""), "server_port": int(cfg.get("port", 0))}
            if cfg.get("id"): out["uuid"] = cfg["id"]
            if cfg.get("aid"): out["alter_id"] = int(cfg["aid"])
            net = cfg.get("net", "")
            if net == "ws":
                out["transport"] = "ws"
                if cfg.get("path"): out["transport_opts"] = {"path": cfg["path"]}
                if cfg.get("host"): out.setdefault("transport_opts", {})["headers"] = {"Host": cfg["host"]}
            elif net == "grpc":
                out["transport"] = "grpc"
            elif net == "tcp":
                out["transport"] = "tcp"
            elif net == "kcp":
                out["transport"] = "kcp"
            tls = cfg.get("tls", "")
            if tls and tls != "none":
                out["tls"] = {"enabled": True, "insecure": cfg.get("allowInsecure", "0") == "1"}
                if cfg.get("sni"): out["tls"]["server_name"] = cfg["sni"]
            return out
        elif proto in ("vless", "trojan"):
            from urllib.parse import urlparse, parse_qs
            parsed = urlparse(uri)
            pw_or_uuid = parsed.username or ""
            host = parsed.hostname or ""
            port = parsed.port or 443
            qs = parse_qs(parsed.query, keep_blank_values=True)
            def g(k): return (qs.get(k) or [None])[0]
            out = {"type": proto, "tag": parsed.fragment or f"{proto}_{host}", "server": host, "server_port": port}
            if proto == "trojan":
                out["password"] = pw_or_uuid
            else:
                out["uuid"] = pw_or_uuid
            # TLS / Reality
            sec = g("security") or "none"
            if sec == "tls":
                out["tls"] = {"enabled": True}
                if g("sni"): out["tls"]["server_name"] = g("sni")
                if g("alpn"): out["tls"]["alpn"] = g("alpn").split(",")
                if g("fp"): out["tls"]["fingerprint"] = g("fp")
                if g("allowInsecure") == "1" or g("allow_insecure") == "1":
                    out["tls"]["insecure"] = True
            elif sec == "reality":
                out["tls"] = {"enabled": True, "reality": {"enabled": True}}
                if g("sni"): out["tls"]["server_name"] = g("sni")
                if g("fp"): out["tls"]["fingerprint"] = g("fp")
                if g("pbk"): out["tls"]["reality"]["public_key"] = g("pbk")
                if g("sid"): out["tls"]["reality"]["short_id"] = g("sid")
            elif proto == "trojan":
                # Trojan всегда использует TLS, даже если параметр security не указан
                out["tls"] = {"enabled": True}
                if g("sni"): out["tls"]["server_name"] = g("sni")
                if g("alpn"): out["tls"]["alpn"] = g("alpn").split(",")
                if g("fp"): out["tls"]["fingerprint"] = g("fp")
            # Transport
            tp = g("type") or "tcp"
            if tp == "ws":
                out["transport"] = "ws"
                opts = {}
                if g("path"): opts["path"] = g("path")
                if g("host"): opts["headers"] = {"Host": g("host")}
                if opts: out["transport_opts"] = opts
            elif tp == "grpc":
                out["transport"] = "grpc"
                if g("serviceName"): out["transport_opts"] = {"service_name": g("serviceName")}
            elif tp in ("tcp", "kcp", "quic"):
                out["transport"] = tp
            # Flow
            if g("flow"): out["flow"] = g("flow")
            return out
        return None
    except Exception:
        return None


def is_safe_proxy(uri: str) -> bool:
    """Проверяет, не содержит ли прокси проблемных возможностей (REALITY, xtls-rprx)."""
    try:
        from urllib.parse import urlparse, parse_qs
        parsed = urlparse(uri)
        qs = parse_qs(parsed.query, keep_blank_values=True)
        sec = (qs.get("security") or [""])[0]
        flow = (qs.get("flow") or [""])[0]
        if sec == "reality":
            return False
        if "xtls-rprx" in flow:
            return False
        if uri.startswith("vless://") and sec == "none" and flow:
            return False
        return True
    except Exception:
        return True


def format_singbox(entries: list[ProxyEntry]) -> str:
    """Экспорт в sing-box JSON (список outbounds)."""
    outbounds = []
    for p in entries:
        ob = uri_to_singbox(p.uri)
        if ob:
            outbounds.append(ob)
    return json.dumps(outbounds, indent=2, ensure_ascii=False)


def format_v2rayn(entries: list[ProxyEntry]) -> str:
    """Base64-encoded subscription для v2rayN."""
    lines = [p.uri for p in entries]
    data = "\n".join(lines).encode()
    return base64.b64encode(data).decode()

def format_raw(entries: list[ProxyEntry]) -> str:
    """Raw URIs по одной на строку."""
    return "\n".join(p.uri for p in entries) + "\n"


