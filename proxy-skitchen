# ─── CLI Runner ───
class CliRunner(QObject):
    def __init__(self):
        super().__init__()
        self._uris: list[str] = []
        self._entries: list[ProxyEntry] = []

    def _json_out(self, data):
        print(json.dumps(data, ensure_ascii=False, default=str))
        sys.stdout.flush()

    def cmd_search(self, args):
        tokens = _auth_data.get("github_tokens", [])
        if args.token:
            tokens = [args.token]
        known = set()
        worker = GitHubSearchWorker(
            args.keywords, known, explicit_repos=args.repos or [],
            time_filter_days=7, github_tokens=tokens,
            max_repos=args.max_repos, max_files=args.max_files,
        )
        found = []
        worker.result_signal.connect(lambda res: found.extend(res))
        worker.run()
        if args.output:
            with open(args.output, "w") as f:
                for s in found:
                    f.write(f"{s['file_url']}\n")
            self._json_out({"status": "ok", "count": len(found), "output": args.output})
        else:
            self._json_out({"status": "ok", "count": len(found), "sources": found})

    def cmd_fetch(self, args):
        try:
            req = urllib.request.Request(args.url, headers={"User-Agent": "proxy-skitchen/1.0"})
            resp = urllib.request.urlopen(req, timeout=15)
            text = resp.read().decode("utf-8", errors="replace")
            uris = []
            for line in text.splitlines():
                line = line.strip()
                if line and not line.startswith("#") and re.match(r'^[a-z]+://', line, re.IGNORECASE):
                    uris.append(line)
            if args.output:
                with open(args.output, "w") as f:
                    for u in uris:
                        f.write(f"{u}\n")
                self._json_out({"status": "ok", "count": len(uris), "output": args.output})
            else:
                self._json_out({"status": "ok", "count": len(uris), "uris": uris})
        except Exception as e:
            self._json_out({"status": "error", "message": str(e)})

    def cmd_test(self, args):
        host, port = get_server_port(args.uri)
        if not host or not port:
            self._json_out({"status": "error", "message": "не удалось распарсить URI"})
            return
        tester = ProxyTester()
        tcp_ok = tester.test_tcp(host, port)
        if not tcp_ok:
            self._json_out({"status": "ok", "tcp": False, "uri": args.uri})
            return
        lat = None
        if args.deep:
            ok, lat, err, proc = tester.test_via_singbox(args.uri, port=9999)
            self._json_out({"status": "ok", "tcp": True, "deep": ok, "latency_ms": lat, "error": err, "uri": args.uri})
        else:
            self._json_out({"status": "ok", "tcp": True, "uri": args.uri})

    def cmd_test_file(self, args):
        with open(args.path) as f:
            uris = [l.strip() for l in f if l.strip() and not l.startswith("#")]
        total = len(uris)
        if total == 0:
            self._json_out({"status": "error", "message": "файл пуст"})
            return
        tcp_ok_list = []
        tester = ProxyTester()
        # Stage 1: TCP
        for i, u in enumerate(uris):
            if args.verbose:
                print(f"TCP {i+1}/{total}...", file=sys.stderr)
            host, port = get_server_port(u)
            if not host or not port:
                continue
            ok = tester.test_tcp(host, port)
            entry = ProxyEntry(uri=u, source="cli")
            entry.tcp_ok = ok
            if ok:
                tcp_ok_list.append(u)
        # Stage 2: Deep
        deep_ok_list = []
        if args.deep and tcp_ok_list:
            if args.verbose:
                print(f"Deep {len(tcp_ok_list)} прокси...", file=sys.stderr)
            for i, u in enumerate(tcp_ok_list):
                if args.verbose:
                    print(f"  deep {i+1}/{len(tcp_ok_list)}...", file=sys.stderr)
                try:
                    ok, lat, err, proc = tester.test_via_singbox(u, port=9999 + (i % 1000))
                    if ok:
                        deep_ok_list.append(u)
                except Exception as e:
                    if args.verbose:
                        print(f"  ✗ {e}", file=sys.stderr)
        result = {
            "total": total,
            "tcp_ok": len(tcp_ok_list),
            "deep_ok": len(deep_ok_list),
        }
        if args.output:
            out_list = deep_ok_list if args.deep else tcp_ok_list
            with open(args.output, "w") as f:
                for u in out_list:
                    f.write(f"{u}\n")
            result["output"] = args.output
        self._json_out({"status": "ok", **result})

    def cmd_pipeline(self, args):
        if args.verbose:
            print("Pipeline: поиск...", file=sys.stderr)
        tokens = _auth_data.get("github_tokens", [])
        if args.token:
            tokens = [args.token]
        known = set()
        worker = GitHubSearchWorker(
            args.keywords, known, explicit_repos=args.repos or [],
            time_filter_days=7, github_tokens=tokens,
            max_repos=args.max_repos, max_files=args.max_files,
        )
        found = []
        worker.result_signal.connect(lambda res: found.extend(res))
        worker.run()
        if not found:
            self._json_out({"status": "ok", "total": 0, "tcp_ok": 0, "deep_ok": 0, "message": "ничего не найдено"})
            return
        # Скачиваем и парсим все найденные подписки
        all_uris = []
        for s in found:
            if args.verbose:
                print(f"  fetch {s['file_url'][:60]}...", file=sys.stderr)
            try:
                resp = urllib.request.urlopen(s['file_url'], timeout=15)
                text = resp.read().decode("utf-8", errors="replace")
                for line in text.splitlines():
                    line = line.strip()
                    if line and not line.startswith("#") and re.match(r'^[a-z]+://', line, re.IGNORECASE):
                        all_uris.append(line)
            except Exception as e:
                if args.verbose:
                    print(f"  ✗ {e}", file=sys.stderr)
        # Дедупликация
        unique = list(dict.fromkeys(all_uris))
        total = len(unique)
        if args.verbose:
            print(f"Pipeline: {total} уникальных URI", file=sys.stderr)
        if total == 0:
            self._json_out({"status": "ok", "total": 0, "tcp_ok": 0, "deep_ok": 0})
            return
        # TCP-тест
        tcp_ok_list = []
        tester = ProxyTester()
        for i, u in enumerate(unique):
            host, port = get_server_port(u)
            if not host or not port:
                continue
            ok = tester.test_tcp(host, port)
            if ok:
                tcp_ok_list.append(u)
        tcp_count = len(tcp_ok_list)
        if args.verbose:
            print(f"Pipeline: TCP ok {tcp_count}/{total}", file=sys.stderr)
        # Deep-тест
        deep_ok_list = []
        if args.deep and tcp_ok_list:
            if args.verbose:
                print(f"Pipeline: deep-тест {len(tcp_ok_list)} прокси...", file=sys.stderr)
            for i, u in enumerate(tcp_ok_list):
                if args.verbose:
                    print(f"  deep {i+1}/{len(tcp_ok_list)}...", file=sys.stderr)
                try:
                    ok, lat, err, proc = tester.test_via_singbox(u, port=9999 + (i % 1000))
                    if ok:
                        deep_ok_list.append(u)
                except:
                    pass
        result = {
            "total": total,
            "tcp_ok": tcp_count,
            "deep_ok": len(deep_ok_list),
        }
        if args.output:
            out_list = deep_ok_list if args.deep else tcp_ok_list
            with open(args.output, "w") as f:
                for u in out_list:
                    f.write(f"{u}\n")
            result["output"] = args.output
        self._json_out({"status": "ok", **result})


