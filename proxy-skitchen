        "proxies:",
    ]
    for p in entries:
        proto = p.protocol
        name = p.remark or f"{proto}-{p.server}"
        name_safe = re.sub(r'[^a-zA-Z0-9_-]', '_', name)[:30]
        if proto == 'vless':
            lines.append(f"  - name: {name_safe}")
            lines.append(f"    type: vless")
            lines.append(f"    server: {p.server}")
            lines.append(f"    port: {p.port}")
            lines.append(f"    uuid: auto")
            lines.append(f"    tls: true")
        elif proto == 'trojan':
            lines.append(f"  - name: {name_safe}")
            lines.append(f"    type: trojan")
            lines.append(f"    server: {p.server}")
            lines.append(f"    port: {p.port}")
            lines.append(f"    password: auto")
        elif proto == 'vmess':
            lines.append(f"  - name: {name_safe}")
            lines.append(f"    type: vmess")
