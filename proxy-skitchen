def _load_settings() -> dict:
    try:
        sz = os.path.getsize(SETTINGS_FILE)
        if sz > 1_000_000:  # >1MB — битый файл, сброс
            os.remove(SETTINGS_FILE)
            return dict(DEFAULT_SETTINGS)
        with open(SETTINGS_FILE) as f:
            s = json.load(f)
            for k, v in DEFAULT_SETTINGS.items():
                s.setdefault(k, v)
            return s
    except Exception:
        return dict(DEFAULT_SETTINGS)

def _save_settings(s: dict):
    os.makedirs(SETTINGS_DIR, exist_ok=True)
    # Токены не сохраняем в settings.json
    s.pop("github_tokens", None)
    tmp = SETTINGS_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(s, f, indent=2, ensure_ascii=False)
    os.replace(tmp, SETTINGS_FILE)  # атомарная замена

def _load_auth() -> dict:
    """Загружает auth.json (только токены). Если файла нет — пустой список."""
    try:
        if os.path.exists(AUTH_FILE):
            with open(AUTH_FILE) as f:
                return json.load(f)
    except Exception:
        pass
    return {"github_tokens": []}

def _save_auth(data: dict):
    """Сохраняет auth.json с правами 0600."""
    os.makedirs(SETTINGS_DIR, exist_ok=True)
    tmp = AUTH_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    os.chmod(tmp, 0o600)
    os.replace(tmp, AUTH_FILE)

