    def _on_gh_search_done_impl(self, keyword: str, found: list[dict]):
        _debug("_on_gh_search_done_impl: start")
        _debug("  enabling btn_github_search")
        self.btn_github_search.setEnabled(True)
        _debug("  calling _set_busy(False)")
        self._set_busy(False)
        _debug("  set_busy done, sb_label")
        self.sb_label.setText("Готов")
        _debug("  sb_label done")

        if not found:
            _debug("  not found, showing dialog")
            QMessageBox.information(self, "Поиск", "Ничего не найдено.\nПопробуй другие слова: vless, v2ray, proxy, subscription, vpn-configs.")
            _debug("  dialog closed, cleanup")
            self._log("  Ничего не найдено.")
            self._cleanup_gh()
            _debug("  cleanup done")
            return

        now = datetime.now().timestamp()
        period_map = {
            "25 мин": 25/1440, "1 час": 1/24, "2 ч": 2/24, "4 ч": 4/24,
            "6 ч": 6/24, "8 ч": 8/24, "10 ч": 10/24, "12 ч": 12/24,
            "14 ч": 14/24, "16 ч": 16/24, "18 ч": 18/24, "20 ч": 20/24,
            "22 ч": 22/24, "24 ч": 1,
            "1 день": 1, "2 дня": 2, "3 дня": 3, "4 дня": 4,
            "5 дней": 5, "6 дней": 6, "7 дней": 7,
        }
        time_days = period_map.get(self.gh_period_combo.currentText(), 1)
        recent_threshold = time_days * 86400
        new_sources = []
        for item in found:
            try:
                uts = datetime.strptime(item["updated"].replace("Z","+00:00")[:19],"%Y-%m-%dT%H:%M:%S").timestamp()
                recent = (now - uts) < recent_threshold
            except:
                recent = False
            new_sources.append({
                "name": item["name"],
                "file_url": item["file_url"],
                "repo_url": item["repo_url"],
                "updated": item["updated"],
                "stars": item["stars"],
                "is_recent": recent,
                "size": item.get("size", 0),
            })

        dialog = QDialog(self)
        dialog.setWindowTitle(f"Найдено {len(new_sources)} файлов подписок на GitHub")
        dialog.setMinimumSize(550, 400)
        layout = QVBoxLayout(dialog)

        info = QLabel(f"По запросу «{keyword}». Свежие выделены зелёным. 📦 = вложенные ссылки (найдены внутри файлов). OK → добавить в источники.")
        info.setWordWrap(True)
        layout.addWidget(info)

        tree = QTreeWidget()
        tree.setHeaderLabels(["", "Название", "URL", "Обновлён", "⭐"])
        tree.setColumnWidth(0, 30)
        tree.setColumnWidth(1, 280)
        tree.setColumnWidth(2, 350)
        tree.setColumnWidth(3, 140)
        tree.setRootIsDecorated(False)

        recent_c = 0
        for s in new_sources:
            item = QTreeWidgetItem()
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(0, Qt.CheckState.Checked if s["is_recent"] else Qt.CheckState.Unchecked)
            item.setText(1, s["name"])
            item.setText(2, s["file_url"])
            item.setText(3, s["updated"][:19])
            item.setText(4, str(s["stars"]))
            item.setData(1, Qt.ItemDataRole.UserRole, s)
            if s["is_recent"]:
                recent_c += 1
                for c in range(5): item.setBackground(c, QBrush(QColor("#e8f5e9")))
            tree.addTopLevelItem(item)

        layout.addWidget(tree)

        # Кнопки выбора
        btn_row = QHBoxLayout()
        btn_recent = QPushButton(f"✓ Свежие ({recent_c})")
        btn_recent.setToolTip("Отметить только обновлённые за последние 6 часов")
        btn_all = QPushButton("✓ Все")
        btn_all.setToolTip("Отметить все найденные источники")
        btn_none = QPushButton("✗ Снять")
        btn_none.setToolTip("Снять отметки со всех")

        def sr():
            for i in range(tree.topLevelItemCount()):
                it = tree.topLevelItem(i)
                it.setCheckState(0, Qt.CheckState.Checked if it.data(1, Qt.ItemDataRole.UserRole)["is_recent"] else Qt.CheckState.Unchecked)
        def sa():
            for i in range(tree.topLevelItemCount()):
                tree.topLevelItem(i).setCheckState(0, Qt.CheckState.Checked)
        def sn():
            for i in range(tree.topLevelItemCount()):
                tree.topLevelItem(i).setCheckState(0, Qt.CheckState.Unchecked)

        btn_recent.clicked.connect(sr)
        btn_all.clicked.connect(sa)
        btn_none.clicked.connect(sn)
        btn_row.addWidget(btn_recent)
        btn_row.addWidget(btn_all)
        btn_row.addWidget(btn_none)
        btn_row.addStretch()
        layout.addLayout(btn_row)

        bb = QDialogButtonBox(QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel)
        layout.addWidget(bb)
        added = []

        def on_ok():
            _debug("  on_ok: start")
            for i in range(tree.topLevelItemCount()):
                it = tree.topLevelItem(i)
                if it.checkState(0) == Qt.CheckState.Checked:
                    d = it.data(1, Qt.ItemDataRole.UserRole)
                    _debug(f"  on_ok: checked #{i} {d.get('name','?') if isinstance(d,dict) else type(d).__name__}")
                    added.append(d)
            _debug(f"  on_ok: total checked={len(added)}")
            QTimer.singleShot(0, dialog.accept)
            _debug("  on_ok: scheduled accept via timer")

        bb.accepted.connect(on_ok)
        bb.rejected.connect(dialog.reject)

        _debug("_on_gh_search_done_impl: showing dialog")
        try:
            result = dialog.exec_()
        except Exception as e:
            _crash_log(f"dialog.exec_() exception: {e}")
            import traceback
            _crash_log(traceback.format_exc())
            self._log(f"  ✗ dialog.exec_() error: {e}")
            self.sb_label.setText("Ошибка диалога")
            self.btn_github_search.setEnabled(True)
            self._set_busy(False)
            self._cleanup_gh()
            return
        _debug(f"_on_gh_search_done_impl: dialog.exec_() returned {result}")
        if result == _Accepted:
            _debug(f"_on_gh_search_done_impl: dialog accepted, added={len(added)}")
            count = 0
            known = set(n for n,_,_ in self.sources)
            for s in added:
                if not isinstance(s, dict) or "name" not in s:
                    continue
                if s["name"] not in known:
                    known.add(s["name"])
                    try:
                        self.sources.append((s["name"], s["file_url"], True))
                        item = QTreeWidgetItem()
                        item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
                        item.setCheckState(0, Qt.CheckState.Checked)
                        item.setText(1, s["name"])
                        item.setText(2, "⏳")
                        item.setData(1, Qt.ItemDataRole.UserRole, s["file_url"])
                        self.src_list.addTopLevelItem(item)
                        count += 1
                    except Exception as e:
                        self._log(f"  ✗ ошибка добавления {s.get('name','?')}: {e}")
            self._log(f"  ✓ Добавлено {count} новых источников")
            if count:
                self._settings["sources"] = [(n, u, e) for n, u, e in self.sources]
                _save_settings(self._settings)
                _debug(f"_on_gh_search_done_impl: showing info dialog, count={count}")
                QMessageBox.information(self, "Готово", f"Добавлено {count} источников.\nНажми «⬇ Загрузить» чтобы получить прокси.")
        _debug("_on_gh_search_done_impl: cleanup")
        self._cleanup_gh()
        _debug("_on_gh_search_done_impl: end")


class _ProxyTestWorker(QObject):
    result_signal = Signal(bool, float, str)  # ok, ms, error

    def __init__(self, host, port, ptype):
        super().__init__()
        self.host = host
        self.port = port
        self.ptype = ptype

    @Slot()
    def run(self):
        try:
            start = time.time()
            if self.ptype == "socks5":
                s = socks.socksocket()
                s.set_proxy(socks.SOCKS5, self.host, int(self.port))
                s.settimeout(5)
                s.connect(("example.com", 80))
                s.sendall(b"GET / HTTP/1.1\r\nHost: example.com\r\nConnection: close\r\n\r\n")
                s.recv(1024)
                s.close()
            else:
                purl = f"http://{self.host}:{self.port}"
                opener = urllib.request.build_opener(
                    urllib.request.ProxyHandler({"http": purl, "https": purl})
                )
                with opener.open("http://example.com", timeout=5):
                    pass
            ms = (time.time() - start) * 1000
            self.result_signal.emit(True, ms, "")
        except Exception as e:
            self.result_signal.emit(False, 0, str(e)[:80])


class GitHubSearchWorker(QObject):
    result_signal = Signal(list)
    error_signal = Signal(str)
    progress_signal = Signal(str)
    count_signal = Signal(int)

    def __init__(self, keywords: list[str], known_sources: list[str], explicit_repos: list[str] | None = None, time_filter_days: int = 0, github_tokens: list[str] | None = None, scanned_repos: set | None = None, max_repos: int = 12, max_files: int = 50):
        super().__init__()
        self.keywords = keywords
        self.explicit_repos = explicit_repos or []
        self.known = set(known_sources)
        self.time_filter_days = time_filter_days
        self.github_tokens = github_tokens or []
        self.scanned = scanned_repos or set()
        self.newly_scanned: list[str] = []
        self.max_repos = max_repos
        self.max_files = max_files
        self._stop = False

    def stop(self):
        self._stop = True
        socket.setdefaulttimeout(0.5)

    @Slot()
    def run(self):
        try:
            results = []
            seen = set()
            tokens = list(self.github_tokens)  # копия, будем перебирать
            tokens.append("")  # пустой = без токена (60 req/h)

            _proxies = {"http": "http://127.0.0.1:12334", "https": "http://127.0.0.1:12334"}
            _http_fb = urllib.request.build_opener(urllib.request.ProxyHandler(_proxies))

            def _api(url, timeout=5):
                time.sleep(0.5)
                attempts = [
                    ("fallback http proxy", _http_fb),
                ]
                s = _load_settings()
                if s.get("proxy_enabled"):
                    ptype = s.get("proxy_type", "http")
                    host = s.get("proxy_host", "127.0.0.1")
                    port = s.get("proxy_port", 12334)
                    if ptype == "socks5":
                        class _SocksOpener(urllib.request.HTTPHandler):
                            def http_open(self, req):
                                def build(host, port=None, timeout=0, **kwargs):
                                    conn = socks.socksocket()
                                    conn.set_proxy(socks.SOCKS5, host, port)
                                    return conn
                                return self.do_open(build, req)
                        attempts.append(("socks5", urllib.request.build_opener(_SocksOpener())))
                    else:
                        url_p = f"http://{host}:{port}"
                        attempts.append(("http proxy", urllib.request.build_opener(urllib.request.ProxyHandler({"http": url_p, "https": url_p}))))
                base_agent = {"User-Agent":"proxy-fetcher/1.0","Accept":"application/vnd.github.v3+json"}
                agent = dict(base_agent)
                for ti, token in enumerate(tokens):
                    agent = dict(base_agent)
                    if token:
                        agent["Authorization"] = f"token {token}"
                    ok = False
                    for label, opener in attempts:
                        if self._stop: return None
                        req = urllib.request.Request(url, headers=agent)
                        try:
                            with opener.open(req, timeout=timeout) as resp:
                                return resp.read()
                        except urllib.error.HTTPError as e:
                            body = e.read().decode("utf-8", errors="replace")[:200]
                            if e.code in (401, 403):
                                if ti < len(tokens) - 1:
                                    self.progress_signal.emit(f"↻ Токен #{ti+1} ошибка {e.code}, пробую следующий...")
                                    ok = True
                                    break  # перейти к следующему токену
                            self.progress_signal.emit(f"⚠️ {label}: HTTP {e.code} — {body}")
                            continue
                        except Exception:
                            continue
                    if ok:
                        continue  # токен не сработал, пробуем следующий
                    # Прокси не сработали — пробуем прямой запрос с этим же токеном
                    if not self._stop:
                        try:
                            req = urllib.request.Request(url, headers=agent)
                            with urllib.request.urlopen(req, timeout=timeout) as resp:
                                return resp.read()
                        except urllib.error.HTTPError as e:
                            body = e.read().decode("utf-8", errors="replace")[:200]
                            if e.code in (401, 403) and ti < len(tokens) - 1:
                                self.progress_signal.emit(f"↻ Токен #{ti+1} ошибка {e.code} (direct), пробую следующий...")
                                ok = True
                                continue
                            self.progress_signal.emit(f"⚠️ direct (токен #{ti+1}): HTTP {e.code} — {body}")
                            return None
                        except Exception as e:
                            self.progress_signal.emit(f"⚠️ direct (токен #{ti+1}): {type(e).__name__} — {e}")
                            return None
                return None

            if self.time_filter_days > 0:
                cutoff = (datetime.now(timezone.utc) - timedelta(days=self.time_filter_days)).strftime("%Y-%m-%dT%H:%M:%SZ")
                time_qual = f" pushed:>{cutoff}"
            else:
                time_qual = ""

            all_repos = []

            # Сначала сканируем явно указанные репозитории
            for full_name in self.explicit_repos:
                if self._stop:
                    break
                full_name = full_name.strip().lower().rstrip('/')
                if full_name in self.known or full_name in self.scanned:
                    self.progress_signal.emit(f"⏭ Пропуск {full_name} (уже в источниках)")
                    continue
                self.newly_scanned.append(full_name)
                self.progress_signal.emit(f"📂 {full_name} (явный репозиторий)...")
                # Рассчитываем branch (гет запрос к репозиторию)
                branch = "main"
                try:
                    repo_info = _api(f"https://api.github.com/repos/{full_name}", timeout=5)
                    if repo_info:
                        rd = json.loads(repo_info)
                        branch = rd.get("default_branch", "main")
                        stars = rd.get("stargazers_count", 0)
                        updated = rd.get("updated_at", "")
                        repo_url = rd.get("html_url", f"https://github.com/{full_name}")
                except Exception:
                    branch = "main"
                    stars = 0
                    updated = ""
                    repo_url = f"https://github.com/{full_name}"
                file_count = 0

                def _walk_explicit(api_url, rel_prefix, current_branch):
                    nonlocal file_count
                    if file_count >= self.max_files:
                        return
                    d = _api(api_url, timeout=5)
                    if not d:
                        return
                    try:
                        entries = json.loads(d)
                        if not isinstance(entries, list):
                            return
                    except Exception:
                        return
                    for entry in entries:
                        if self._stop or file_count >= self.max_files:
                            break
                        if entry.get("type") == "dir":
                            sub = entry['name']
                            _walk_explicit(entry.get("url", ""), f"{rel_prefix}/{sub}" if rel_prefix else sub, current_branch)
                        elif entry.get("type") != "file":
                            continue
                        else:
                            fname = entry.get("name", "")
                            fext = fname.lower().rsplit('.', 1)[-1] if '.' in fname else ''
                            if fext not in ('txt', 'yaml', 'yml', 'json', 'conf', 'cfg', 'ini', 'list',
                                            'sub', 'sublist', 'uri', 'urls', 'proxy', 'config', 'node', ''):
                                continue
                            fname_lower = fname.lower()
                            skip_prefixes = ('readme', 'license', 'changelog', 'changes', 'todo', 'requirements', 'contributing')
                            skip_names = {'readme.txt', 'license.txt', 'changelog.txt', 'todo.txt', 'requirements.txt',
                                          'readme.md', 'license', 'changelog.md', 'contributing.md'}
                            if fname_lower in skip_names or any(fname_lower.startswith(p) for p in skip_prefixes):
                                continue
                            if fext in ('yml', 'yaml') and rel_prefix and '.github' in rel_prefix:
                                continue
                            path_parts = [full_name, current_branch]
                            if rel_prefix:
                                path_parts.append(rel_prefix)
                            path_parts.append(fname)
                            raw = "https://raw.githubusercontent.com/" + "/".join(path_parts)
                            if raw in seen:
                                continue
                            if raw in self.known:
                                continue
                            fsize = entry.get("size", 0)
                            if fsize < 20 or fsize > 5242880:
                                continue
                            self.progress_signal.emit(f"📄 {full_name}/{rel_prefix or ''}{'/' if rel_prefix else ''}{fname} ({fsize} bytes)...")
                            api_file_url = entry.get("url", "")
                            content = _api(api_file_url, timeout=10)
                            if not content:
                                continue
                            text = ""
                            try:
                                fj = json.loads(content)
                                if "content" in fj:
                                    text = base64.b64decode(fj["content"]).decode("utf-8", errors="replace")[:500000]
                                else:
                                    text = content.decode("utf-8", errors="replace")[:500000]
                            except Exception:
                                text = content.decode("utf-8", errors="replace")[:500000]
                            has_proxy = bool(re.search(r'(?:vless|vmess|trojan|ss|hysteria2?|hy2|tuic|socks4|socks5?)://', text, re.IGNORECASE))
                            has_raw = 'raw.githubusercontent.com' in text
                            has_ipport = bool(re.search(r'(?:\d{1,3}\.){3}\d{1,3}:\d+', text)) or bool(re.search(r'[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.[a-z]{2,}:\d+', text, re.IGNORECASE))
                            has_json_proxy = (text.strip().startswith('{') or text.strip().startswith('[')) and (
                                bool(re.search(r'"(?:type|protocol)"\s*:\s*"(?:vless|vmess|trojan|ss|shadowsocks|hysteria|hy2|tuic|socks|http|wireguard)"', text, re.IGNORECASE)) or
                                (bool(re.search(r'"(?:server|address|add)"\s*:\s*"[^"]+"', text)) and bool(re.search(r'"(?:port|server_port)"\s*:\s*\d+', text)))
                            )
                            if not has_proxy and not has_raw and not has_ipport and not has_json_proxy:
                                continue
                            seen.add(raw)
                            file_count += 1
                            self.progress_signal.emit(f"  ✓ Найден файл с прокси: {fname}")
                            label = f"{full_name}/{rel_prefix}/{fname}" if rel_prefix else f"{full_name}/{fname}"
                            results.append({
                                "name": label,
                                "file_url": raw,
                                "repo_url": repo_url,
                                "updated": updated,
                                "stars": stars,
                                "size": fsize,
                            })
                            self.count_signal.emit(len(results))

                _walk_explicit(f"https://api.github.com/repos/{full_name}/contents?ref={branch}", "", branch)

            # Поиск по ключевым словам
            for kw in self.keywords:
                if self._stop:
                    break
                self.progress_signal.emit(f"🔍 Поиск по запросу: {kw}")
                try:
                    q = urllib.parse.quote(f"{kw}{time_qual}")
                    url = f"https://api.github.com/search/repositories?q={q}&sort=updated&per_page=15"
                    self.progress_signal.emit(f"  URL: {url}")
                    data = _api(url, timeout=8)
                    if data is None:
                        self.progress_signal.emit(f"⚠️ GitHub API недоступен для «{kw}»")
                        continue
                    repos = json.loads(data).get("items", [])
                    self.progress_signal.emit(f"📦 Запрос «{kw}»: {len(repos)} репозиториев")
                    all_repos.extend(repos)
                except Exception as e:
                    self.progress_signal.emit(f"❌ Ошибка для «{kw}»: {e}")
                    continue

            # Дедупликация репозиториев по full_name
            seen_repos = set()
            unique_repos = []
            for repo in all_repos:
                full = repo.get("full_name", "")
                if full not in seen_repos:
                    seen_repos.add(full)
                    unique_repos.append(repo)

            self.progress_signal.emit(f"📊 Найдено уникальных репозиториев: {len(unique_repos)}")

            for idx, repo in enumerate(unique_repos):
                if self._stop: break
                if idx >= self.max_repos: break

                full = repo.get("full_name", "")
                branch = repo.get("default_branch", "main")
                updated = repo.get("updated_at", "")
                stars = repo.get("stargazers_count", 0)
                repo_url = repo.get("html_url", "")
                if repo_url in self.known or full in self.known:
                    self.progress_signal.emit(f"⏭ Пропуск {full} (уже в источниках)")
                    continue
                if full in self.scanned:
                    self.progress_signal.emit(f"⏭ Пропуск {full} (уже просканирован)")
                    continue
                self.newly_scanned.append(full)

                self.progress_signal.emit(f"📂 {full} ({stars}⭐)...")
                file_count = 0

                def _walk(api_url, rel_prefix, current_branch):
                    nonlocal file_count
                    if file_count >= self.max_files:
                        return
                    d = _api(api_url, timeout=5)
                    if not d:
                        self.progress_signal.emit(f"  ⚠️ Не удалось получить содержимое {api_url[:60]}...")
                        return
                    try:
                        entries = json.loads(d)
                        if not isinstance(entries, list):
                            self.progress_signal.emit(f"  ⚠️ Неожиданный формат ответа от GitHub API")
                            return
                    except Exception as e:
                        self.progress_signal.emit(f"  ⚠️ Ошибка парсинга: {e}")
                        return
                    for entry in entries:
                        if self._stop or file_count >= self.max_files: break
                        if entry.get("type") == "dir":
                            sub = entry['name']
                            _walk(entry.get("url", ""), f"{rel_prefix}/{sub}" if rel_prefix else sub, current_branch)
                        elif entry.get("type") != "file":
                            continue
                        else:
                            fname = entry.get("name", "")
                            fext = fname.lower().rsplit('.', 1)[-1] if '.' in fname else ''
                            if fext not in ('txt', 'yaml', 'yml', 'json', 'conf', 'cfg', 'ini', 'list',
                                            'sub', 'sublist', 'uri', 'urls', 'proxy', 'config', 'node', ''):
                                continue
                            fname_lower = fname.lower()
                            skip_prefixes = ('readme', 'license', 'changelog', 'changes', 'todo', 'requirements', 'contributing')
                            skip_names = {'readme.txt', 'license.txt', 'changelog.txt', 'todo.txt', 'requirements.txt',
                                          'readme.md', 'license', 'changelog.md', 'contributing.md'}
                            if fname_lower in skip_names or any(fname_lower.startswith(p) for p in skip_prefixes):
                                continue

                            if fext in ('yml', 'yaml') and rel_prefix and '.github' in rel_prefix:
                                self.progress_signal.emit(f"  ⏭ {fname} — CI/workflow файл")
                                continue

                            path_parts = [full, current_branch]
                            if rel_prefix:
                                path_parts.append(rel_prefix)
                            path_parts.append(fname)
                            raw = "https://raw.githubusercontent.com/" + "/".join(path_parts)
                            if raw in seen: continue
                            if raw in self.known:
                                self.progress_signal.emit(f"  ⏭ {fname} (уже в источниках)")
                                continue

                            fsize = entry.get("size", 0)
                            if fsize < 20 or fsize > 5242880:
                                self.progress_signal.emit(f"  ⏭ Пропуск {fname} (размер: {fsize})")
                                continue

                            full_path = f"{full}/{rel_prefix}/{fname}" if rel_prefix else f"{full}/{fname}"
                            self.progress_signal.emit(f"📄 {full_path} ({fsize} bytes)...")
                            # Используем API вместо raw.githubusercontent.com (SSL проблемы)
                            api_file_url = entry.get("url", "")
                            content = _api(api_file_url, timeout=10)
                            if not content:
                                self.progress_signal.emit(f"  ⚠️ Не удалось скачать {raw[:80]}...")
                                continue
                            text = ""
                            try:
                                fj = json.loads(content)
                                if "content" in fj:
                                    text = base64.b64decode(fj["content"]).decode("utf-8", errors="replace")[:500000]
                                else:
                                    text = content.decode("utf-8", errors="replace")[:500000]
                            except Exception:
                                text = content.decode("utf-8", errors="replace")[:500000]
                            has_proxy = bool(re.search(r'(?:vless|vmess|trojan|ss|hysteria2?|hy2|tuic|socks4|socks5?)://', text, re.IGNORECASE))
                            has_raw = 'raw.githubusercontent.com' in text or 'github.com' in text
                            has_ipport = bool(re.search(r'(?:\d{1,3}\.){3}\d{1,3}:\d+', text)) or bool(re.search(r'[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.[a-z]{2,}:\d+', text, re.IGNORECASE))
                            has_json_proxy = (text.strip().startswith('{') or text.strip().startswith('[')) and (
                                bool(re.search(r'"(?:type|protocol)"\s*:\s*"(?:vless|vmess|trojan|ss|shadowsocks|hysteria|hy2|tuic|socks|http|wireguard)"', text, re.IGNORECASE)) or
                                (bool(re.search(r'"(?:server|address|add)"\s*:\s*"[^"]+"', text)) and bool(re.search(r'"(?:port|server_port)"\s*:\s*\d+', text)))
                            )
                            if not has_proxy and not has_raw and not has_ipport and not has_json_proxy:
                                self.progress_signal.emit(f"  ⏭ {fname} не содержит прокси или ссылок GitHub")
                                continue
                            seen.add(raw)
                            file_count += 1
                            self.progress_signal.emit(f"  ✓ Найден файл с прокси: {fname}")

                            is_raw_list = has_raw and not has_proxy
                            label = full_path
                            results.append({
                                "name": label,
                                "file_url": raw,
                                "repo_url": repo_url,
                                "updated": updated,
                                "stars": stars,
                                "size": fsize,
                            })
                            self.count_signal.emit(len(results))

                            if is_raw_list:
                                for m in re.finditer(r'https://raw\.githubusercontent\.com/[^\s<>"\'\\]+\.txt', text):
                                    if self._stop: break
                                    eurl = m.group(0).rstrip("/.,;:!?)")
                                    if eurl in seen: continue
                                    seen.add(eurl)
                                    eparts = eurl.replace("https://raw.githubusercontent.com/", "").split("/")
                                    ename = f"📦 {full}/{fname} → {eparts[-1]}" if len(eparts) >= 3 else f"📦 {full}/{fname} → (url)"
                                    results.append({
                                        "name": ename,
                                        "file_url": eurl,
                                        "repo_url": repo_url,
                                        "updated": updated,
                                        "stars": stars,
                                        "size": 0,
                                        "embedded": True,
                                    })

                try:
                    _walk(f"https://api.github.com/repos/{full}/contents?ref={branch}", "", branch)
                except Exception:
                    continue

            results.sort(key=lambda r: r.get("embedded", False))
            if self._stop:
                self.progress_signal.emit(f"⏹ Поиск остановлен. Найдено: {len(results)}")
            else:
                self.progress_signal.emit(f"✅ Поиск завершён. Найдено: {len(results)}")
            self.result_signal.emit(results)
        except Exception as e:
            import traceback
            err = f"Критическая ошибка поиска: {e}\n{traceback.format_exc()}"
            self.error_signal.emit(err)


