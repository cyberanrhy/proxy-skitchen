        self._gh_thread.started.connect(self._gh_worker.run, Qt.ConnectionType.DirectConnection)
        _debug(f"  thread started, worker={id(self._gh_worker)}")
        self._gh_thread.start()

    def _cleanup_gh(self):
        if self._gh_worker:
            self._gh_worker.stop()
            try:
                self._gh_worker.result_signal.disconnect()
            except Exception:
                pass
            try:
                self._gh_worker.error_signal.disconnect()
            except Exception:
                pass
            try:
                self._gh_worker.progress_signal.disconnect()
            except Exception:
                pass
            self._gh_worker.deleteLater()
        if self._gh_thread:
            self._kill_thread(self._gh_thread, "gh")
            self._gh_thread.deleteLater()
            self._gh_thread = None
        self._gh_worker = None

