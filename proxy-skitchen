        cfg = PERF_PRESETS.get(self._settings.get("perf_mode", "medium"))
        self._test_thread = QThread()
        self._test_worker = TesterWorker(deep=deep, test_threads=cfg["test_threads"], deep_threads=cfg["deep_threads"])
        self._test_worker.moveToThread(self._test_thread)
