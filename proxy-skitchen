    def _on_add_repo(self):
        url = self.gh_repo_url.text().strip()
        if not url:
            return
        m = re.search(r'github\.com/([^/]+/[^/]+?)(?:/|$|\.git)', url)
        if not m:
            QMessageBox.warning(self, "Ошибка", "Не удалось распарсить GitHub URL.\nПример: https://github.com/owner/repo")
            return
        full_name = m.group(1).lower()
        if full_name in self.gh_selected_repos:
            self.gh_repo_url.clear()
            return
        self.gh_selected_repos.append(full_name)
        self.gh_repo_url.clear()
        self._update_repo_chips()
        self._settings["gh_selected_repos"] = self.gh_selected_repos
        _save_settings(self._settings)

    def _on_repo_remove(self, full_name):
        if full_name in self.gh_selected_repos:
            self.gh_selected_repos.remove(full_name)
            self._update_repo_chips()
            self._settings["gh_selected_repos"] = self.gh_selected_repos
            _save_settings(self._settings)

    def _update_repo_chips(self):
        for _, btn in self.gh_repo_btns:
            self.gh_repo_layout.removeWidget(btn)
            btn.deleteLater()
        self.gh_repo_btns.clear()
        for r in self.gh_selected_repos:
            btn = QPushButton(f"✕ {r}")
            btn.setFixedHeight(22)
            btn.setStyleSheet(
                "QPushButton { font-size: 9px; padding: 1px 6px; border: 1px solid #6a6a6a; border-radius: 3px; background: #4a4a4a; color: #ddd; }"
                "QPushButton:hover { background: #c62828; color: #fff; border-color: #ef5350; }"
            )
            btn.setToolTip(f"Удалить {r}")
            btn.clicked.connect(lambda checked, name=r: self._on_repo_remove(name))
            self.gh_repo_layout.addWidget(btn)
            self.gh_repo_btns.append((r, btn))
        self.gh_repo_layout.addStretch()

