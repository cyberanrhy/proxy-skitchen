    # ─── REMOVE DEAD ───

    def _on_remove_dead(self):
        proxies = self.proxy_model.proxies
        if not proxies:
            return
        dead_count = sum(1 for p in proxies if p.tcp_ok is False or p.deep_ok is False)
        if dead_count == 0:
            QMessageBox.information(self, "Нет нерабочих", "Нерабочих прокси не найдено.")
            return
        reply = QMessageBox.question(self, "Удалить нерабочие",
            f"Найдено {dead_count} нерабочих прокси (TCP или Deep-тест не пройден).\nУдалить их из таблицы?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        if reply != QMessageBox.StandardButton.Yes:
            return
        before = len(proxies)
        proxies[:] = [p for p in proxies if p.tcp_ok is not False and p.deep_ok is not False]
        self.proxy_model.beginResetModel()
        self.proxy_model.endResetModel()
        removed = before - len(proxies)
        self._log(f"🗑 Удалено нерабочих: {removed}")
        self._update_stats()

    # ─── SAVE ───

    def _on_save(self):
        proxies = self.proxy_model.proxies
        if not proxies:
            QMessageBox.information(self, "Нет данных", "Нет прокси для сохранения.")
            return

        working = [p for p in proxies if p.deep_ok is True or p.tcp_ok is True]
        deep_ok = [p for p in proxies if p.deep_ok is True]
        tcp_ok = [p for p in proxies if p.tcp_ok is True and p.deep_ok is not True]
        sni_ok = [p for p in proxies if p.sni_good]

        os.makedirs(OUT_DIR, exist_ok=True)
        ts = datetime.now().strftime("%m.%d_%H%M")

        files = []

        def save(name, data):
            path = os.path.join(OUT_DIR, name)
            with open(path, "w") as f:
                f.write("\n".join(p.uri for p in data) + "\n")
            files.append((name, len(data)))

        # Simple formats
        if deep_ok:
            save(f"DEEP_WORKING_{ts}.txt", deep_ok)
        if working:
            save(f"WORKING_{ts}.txt", working)
        save(f"ALL_{ts}.txt", proxies)
        if sni_ok:
            save(f"SNI_{ts}.txt", sni_ok)

        for proto in ['vless', 'vmess', 'trojan', 'ss', 'hy2']:
            pp = [p for p in proxies if p.protocol == proto]
            if pp: save(f"{proto.upper()}_{ts}.txt", pp)

        # Multi-format export
        if deep_ok:
            save(f"CLASH_{ts}.yaml", [])
            with open(os.path.join(OUT_DIR, f"CLASH_{ts}.yaml"), "w") as f:
                f.write(format_clash(deep_ok))
            files.append((f"CLASH_{ts}.yaml", len(deep_ok)))

            save(f"SINGBOX_{ts}.json", [])
            with open(os.path.join(OUT_DIR, f"SINGBOX_{ts}.json"), "w") as f:
                f.write(format_singbox(deep_ok))
            files.append((f"SINGBOX_{ts}.json", len(deep_ok)))

            save(f"V2RAYN_{ts}.txt", [])
            with open(os.path.join(OUT_DIR, f"V2RAYN_{ts}.txt"), "w") as f:
                f.write(format_v2rayn(deep_ok))
            files.append((f"V2RAYN_{ts}.txt", len(deep_ok)))

        # latest subscription (base64 v2rayN)
        if working:
