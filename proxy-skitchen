        self._tokens_timer.start(1000)

    def _save_tokens_now(self):
        tokens = [t.strip() for t in self.github_tokens_edit.toPlainText().strip().splitlines() if t.strip()]
        _auth_data["github_tokens"] = tokens
        _save_auth(_auth_data)

    def _save_proxy_settings(self):
        tokens = [t.strip() for t in self.github_tokens_edit.toPlainText().strip().splitlines() if t.strip()]
        self._log(f"🔧 Сохранение настроек... (токенов: {len(tokens)})")
        _auth_data["github_tokens"] = tokens
        _save_auth(_auth_data)
        self._settings["proxy_enabled"] = self.cb_proxy_enable.isChecked()
        self._settings["proxy_type"] = self.proxy_type_combo.currentText().lower()
        self._settings["proxy_host"] = self.proxy_host_edit.text().strip()
        self._settings["proxy_port"] = self.proxy_port_spin.value()
        _save_settings(self._settings)
        _invalidate_proxy_cache()
        self.sb_label.setText("✅ Настройки сохранены")

    def _on_proxy_toggle(self, enabled: bool):
