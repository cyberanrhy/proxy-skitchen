    p_fetch = sub.add_parser("fetch", help="Скачать и спарсить подписку")
    p_fetch.add_argument("url", help="URL подписки")
    p_fetch.add_argument("--output", help="Сохранить URI в файл")

    p_test = sub.add_parser("test", help="TCP-тест одного прокси")
    p_test.add_argument("uri", help="Прокси-URI (vless://, vmess://, ...)")
    p_test.add_argument("--deep", action="store_true", help="Глубокий тест через sing-box")

    p_testf = sub.add_parser("test-file", help="Проверить все URI из файла")
    p_testf.add_argument("path", help="Файл с URI (построчно)")
    p_testf.add_argument("--deep", action="store_true", help="Глубокий тест через sing-box")
    p_testf.add_argument("--output", help="Сохранить только рабочие")

    p_pipe = sub.add_parser("pipeline", help="Полный конвейер: поиск → тест → сохранение")
    p_pipe.add_argument("keywords", nargs="+", help="Ключевые слова")
    p_pipe.add_argument("--repos", nargs="*", default=[], help="Явные репозитории")
    p_pipe.add_argument("--deep", action="store_true", help="Глубокий тест")
    p_pipe.add_argument("--output", help="Сохранить валидные прокси")
    p_pipe.add_argument("--timeout", type=int, default=300, help="Таймаут (сек)")
    p_pipe.add_argument("--max-repos", type=int, default=15)
    p_pipe.add_argument("--max-files", type=int, default=50)
    p_pipe.add_argument("--token", help="GitHub токен")

    args = parser.parse_args()
    if args.command:
        app = QCoreApplication(sys.argv)
        app.setApplicationName("proxy-skitchen")
        runner = CliRunner()
        getattr(runner, f"cmd_{args.command.replace('-', '_')}")(args)
    else:
        main()
