    def _update_stats(self):
        p = self.proxy_model.proxies
        total = len(p)
        visible = self.filter_model.rowCount() if hasattr(self, 'filter_model') else total
        tested = sum(1 for x in p if x.tcp_ok is not None or x.deep_ok is not None)
        ok = sum(1 for x in p if x.deep_ok is True or x.tcp_ok is True)
        label = f"🔌 {visible}/{total}"
        if tested:
            label += f"  ✅{ok} ❌{tested - ok} ⏳{total - tested}"
        self.proxy_count_label.setText(label)
        self.btn_stats.setEnabled(total > 0)
