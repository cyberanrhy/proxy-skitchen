    finished_signal = Signal()
    proxy_parsed = Signal(list)  # batch of URI strings
    source_status = Signal(str, bool, int)

    def __init__(self):
        super().__init__()
        self._stop = False

    def stop(self): self._stop = True

    def _is_proxy(self, s: str) -> bool:
        l = s.strip().lower()
        prefixes = ('vless://','vmess://','trojan://','ss://','shadowsocks://',
                    'hysteria2://','hy2://','hysteria://','hy://','tuic://',
                    'socks5://','socks4://','http://','https://','naive+',
                    'wireguard://','wg://')
        if l.startswith(prefixes):
            return True
        if re.match(r'^\d{1,3}(?:\.\d{1,3}){3}:\d+$', l):
            return True
        if re.match(r'^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.[a-z]{2,}:\d+$', l, re.IGNORECASE):
            return True
        return False

    def _json_to_uri(self, obj: dict) -> Optional[str]:
        ptype = (obj.get("type") or obj.get("protocol") or "").lower()
        server = obj.get("server") or obj.get("address") or obj.get("add") or ""
        port = obj.get("port") or obj.get("server_port") or 0
        if not server or not port:
            return None
        try: port = int(port)
        except: return None
        tag = obj.get("tag") or obj.get("name") or obj.get("remark") or ""
        if ptype == "vmess":
            vm = {"v": 2, "ps": tag, "add": server, "port": port,
                  "id": obj.get("uuid") or obj.get("id") or "",
                  "aid": obj.get("aid") or obj.get("alterId") or 0,
                  "net": obj.get("network") or obj.get("net") or "tcp",
                  "type": "none", "host": "", "path": "", "tls": ""}
            tls = obj.get("tls") or {}
            if isinstance(tls, dict):
                if tls.get("enabled"):
                    vm["tls"] = "tls"
                    vm["sni"] = tls.get("server_name", "")
            elif isinstance(tls, str):
                vm["tls"] = tls
            b64 = base64.b64encode(json.dumps(vm).encode()).decode()
            return f"vmess://{b64}"
        uuid = obj.get("uuid") or obj.get("id") or obj.get("password") or obj.get("auth") or ""
        params = {}
        tls = obj.get("tls") or {}
        if isinstance(tls, dict) and tls.get("enabled"):
            params["security"] = "tls"
            if tls.get("server_name"):
                params["sni"] = tls["server_name"]
        flow = obj.get("flow") or ""
        if flow: params["flow"] = flow
        if obj.get("insecure"):
            params["insecure"] = "1"
        enc = obj.get("encryption") or obj.get("method") or (obj.get("security") if ptype != "vless" else "")
        if enc and enc != "none": params["encryption"] = enc
        obj_type = ptype
        if obj_type == "shadowsocks":
            obj_type = "ss"
            if enc and uuid:
                userinfo = base64.urlsafe_b64encode(f"{enc}:{uuid}".encode()).decode().rstrip("=")
                return f"ss://{userinfo}@{server}:{port}{f'#{urllib.parse.quote(tag)}' if tag else ''}"
        elif obj_type in ("hysteria2", "hysteria"):
            obj_type = "hy2" if obj_type == "hysteria2" else "hy"
        elif obj_type in ("socks5", "socks"):
            obj_type = "socks5"
        param_str = "&".join(f"{k}={urllib.parse.quote(str(v))}" for k, v in params.items())
        uri = f"{obj_type}://"
        if uuid: uri += f"{uuid}@"
        uri += f"{server}:{port}"
        if param_str: uri += f"?{param_str}"
        if tag: uri += f"#{urllib.parse.quote(tag)}"
        return uri

    def _parse_json_proxies(self, text: str) -> list[str]:
        s = text.strip()
        if not (s.startswith("{") or s.startswith("[")):
            return []
        try: data = json.loads(s)
        except: return []
        results = []
        def walk(obj, depth=0):
            if depth > 4: return
            if isinstance(obj, dict):
                if obj.get("server") or obj.get("address") or obj.get("add"):
                    uri = self._json_to_uri(obj)
                    if uri: results.append(uri)
                    return
                for v in obj.values(): walk(v, depth + 1)
            elif isinstance(obj, list):
                for n, item in enumerate(obj):
                    if isinstance(item, str):
                        if self._is_proxy(item):
                            results.append(item)
                    else:
                        walk(item, depth + 1)
        walk(data)
        return results

    def _fetch_one(self, name: str, url: str):
        m = re.match(r'https://github\.com/([^/]+/[^/]+)/blob/(.+)$', url)
        if m:
            url = f'https://raw.githubusercontent.com/{m.group(1)}/{m.group(2)}'
        def _do(use_proxy=False):
            opener, _ = _get_proxy_opener(timeout=8) if use_proxy else (urllib.request.build_opener(), {})
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"})
            try:
                with opener.open(req, timeout=8) as resp:
                    return resp.read().decode("utf-8", errors="ignore")
            except Exception:
                return None
        data = _do(False) or _do(True)
        if data is None:
            return None
        proxies = []
        for line in data.splitlines():
            line = line.strip()
            if not line or line.startswith('//') or line.startswith('#'):
                continue
            if re.match(r'^[A-Za-z0-9+/=]{50,}$', line):
                try:
                    decoded = base64.b64decode(line).decode("utf-8", errors="ignore")
                    for sl in decoded.splitlines():
                        sl = sl.strip()
                        if sl and self._is_proxy(sl): proxies.append(sl)
                except Exception:
                    if self._is_proxy(line): proxies.append(line)
            else:
                if self._is_proxy(line): proxies.append(line)
        json_proxies = self._parse_json_proxies(data)
        for p in json_proxies:
            if p and p not in proxies:
                proxies.append(p)
        wrapped = []
        for p in proxies:
            if re.match(r'^\d{1,3}(?:\.\d{1,3}){3}:\d+$', p) or re.match(r'^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.[a-z]{2,}:\d+$', p, re.IGNORECASE):
                wrapped.append(f"socks5://{p}")
            else:
                wrapped.append(p)
        return wrapped

    @Slot()
    def fetch_all(self, sources: list[tuple[str, str]]):
        self._stop = False
        total = len(sources)
        pool = ThreadPoolExecutor(max_workers=4)
        futs: list[concurrent.futures.Future] = []
        names: list[str] = []
        try:
            for name, url in sources:
                if self._stop: break
                futs.append(pool.submit(self._fetch_one, name, url))
                names.append(name)
            pending: set[concurrent.futures.Future] = set(futs)
            while pending and not self._stop:
                done, pending = wait(pending, timeout=1.0)
                for fut in done:
                    idx = next(i for i, f in enumerate(futs) if f is fut)
                    name = names[idx]
                    self.progress_signal.emit(idx + 1, total, name)
                    proxies = fut.result()
                    if proxies is None:
                        self.log_signal.emit(f"  ✗ {name}: не удалось загрузить")
                        self.source_status.emit(name, False, 0)
                    else:
                        count = 0
                        batch: list[str] = []
                        for uri in proxies:
                            if self._stop: break
                            batch.append(uri)
                            count += 1
                            if len(batch) >= 50:
                                self.proxy_parsed.emit(batch)
                                batch = []
                        if batch:
                            self.proxy_parsed.emit(batch)
                        self.source_status.emit(name, True, count)
                        self.log_signal.emit(f"  ✓ {name}: {count} прокси")
        finally:
            for fut in futs:
                fut.cancel()
            pool.shutdown(wait=False, cancel_futures=True)
        self.progress_signal.emit(total, total, "Готово")
        self.finished_signal.emit()


class TesterWorker(QObject):
    log_signal = Signal(str)
    progress_signal = Signal(int, int, int, str)  # row, current, total, name
    finished_signal = Signal()
    result_signal = Signal(int, bool, float, str, int)  # row, ok, latency, error, type (0=tcp, 1=deep)

    def __init__(self, deep: bool = False, test_threads: int = 8, deep_threads: int = 4):
        super().__init__()
        self._stop = False
        self._deep = deep
        self._timeout = 12.0
        self._sb_procs: list[subprocess.Popen] = []
        self._test_threads = test_threads
        self._deep_threads = deep_threads

    def stop(self):
        self._stop = True
        socket.setdefaulttimeout(0.5)
        for proc in self._sb_procs:
            try: proc.terminate()
            except Exception: pass
        self._sb_procs.clear()

    @Slot()
    def test_batch(self, entries: list[tuple[int, ProxyEntry]]):
        self._stop = False
        self._sb_procs.clear()
        deep = self._deep
        total = len(entries)
        tester = ProxyTester()

        def _work(args):
            idx, row, p = args
            if self._stop:
                return None
            host, port = p.server, p.port
            if not host or not port:
                return (row, False, 0, "no server:port", 0 if not deep else 1)

            start = time.monotonic()
            tcp_ok = tester.test_tcp(host, port)
            if not tcp_ok:
                return (row, False, 0, "TCP refused", 0)

            tcp_latency = (time.monotonic() - start) * 1000

            if not deep:
                return (row, True, tcp_latency, "", 0)

            try:
                ok, sb_latency, error, proc = tester.test_via_singbox(p.uri, port=9999 + (row % 1000))
                if proc:
                    self._sb_procs.append(proc)
                return (row, ok, sb_latency, error, 1)
            except Exception as e:
                return (row, False, 0, str(e), 1)

        pool = ThreadPoolExecutor(max_workers=self._deep_threads if self._deep else self._test_threads)
        try:
            args_list = [(idx, row, p) for idx, (row, p) in enumerate(entries)]
            futures = {pool.submit(_work, a): a for a in args_list}
            pending = set(futures.keys())

            while pending and not self._stop:
                done, pending = wait(pending, timeout=0.5)
                for future in done:
                    idx = futures[future][0]
                    self.progress_signal.emit(-1, idx + 1, total, f"... {idx+1}/{total}")
                    result = future.result()
                    if result is None:
                        continue
                    row, ok, latency, error, ttype = result
                    self.result_signal.emit(row, ok, latency, error, ttype)
        finally:
            pool.shutdown(wait=False, cancel_futures=True)

        self.finished_signal.emit()


class _SourceFetcher(QObject):
    result = Signal(str)
    error = Signal(str)

    def __init__(self, url):
        super().__init__()
        self._url = url

    @Slot()
    def run(self):
        try:
            data = None
            for use_proxy in (False, True):
                opener, _ = _get_proxy_opener(timeout=8) if use_proxy else (urllib.request.build_opener(), {})
                req = urllib.request.Request(self._url, headers={"User-Agent": "Mozilla/5.0"})
                try:
                    with opener.open(req, timeout=8) as resp:
                        data = resp.read().decode("utf-8", errors="ignore")
                        break
                except Exception:
                    continue
            if data is not None:
                self.result.emit(data[:50000])
            else:
                self.error.emit("Не удалось загрузить (прямой доступ и прокси)")
        except Exception as e:
            self.error.emit(str(e))

