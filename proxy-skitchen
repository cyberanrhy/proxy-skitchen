    def _on_remove_source(self):
        # Сначала пробуем выбранные (selected), если нет — отмеченные галочкой (checked)
        selected = self.src_list.selectedItems()
        if not selected:
            # Берём все checked-элементы
            selected = [
                self.src_list.topLevelItem(i)
                for i in range(self.src_list.topLevelItemCount())
                if self.src_list.topLevelItem(i).checkState(0) == Qt.CheckState.Checked
            ]
        if not selected:
            QMessageBox.information(self, "Удаление", "Выбери или отметь источник для удаления.")
            return
        # Удаляем с конца к началу, чтобы индексы не сдвигались
        for item in sorted(selected, key=lambda i: self.src_list.indexOfTopLevelItem(i), reverse=True):
            name = item.text(1)
            self.sources = [(n, u, e) for n, u, e in self.sources if n != name]
            idx = self.src_list.indexOfTopLevelItem(item)
            if idx >= 0:
                self.src_list.takeTopLevelItem(idx)

